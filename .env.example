# =========================================================================
# GraphRAG Docs Assistant — environment configuration
# Copy this file to `.env` and fill in the values.
# =========================================================================

# ---- LLM provider -------------------------------------------------------
# Which backend to use for generation: "anthropic" (default) or "ollama".
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic).
# The default Anthropic model id MUST be claude-opus-4-8.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# Ollama (used when LLM_PROVIDER=ollama).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---- Embeddings ---------------------------------------------------------
# Any sentence-transformers model id.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Vector store (ChromaDB) -------------------------------------------
CHROMA_DIR=./.chroma
CHROMA_COLLECTION=graphrag_docs

# ---- Knowledge graph (Neo4j) -------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# ---- Relational store (PostgreSQL) -------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphrag
POSTGRES_USER=graphrag
POSTGRES_PASSWORD=please-change-me

# ---- Ingestion ----------------------------------------------------------
DOCS_DIR=./docs
CHUNK_SIZE=800
CHUNK_OVERLAP=120
